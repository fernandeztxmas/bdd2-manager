-- Funcion que no recibe parámetros, envia a la consola
-- valores según el scope de la variable mostrada
CREATE FUNCTION somefunc() RETURNS integer AS $$
<< outerblock >>
DECLARE
    quantity integer := 30;
BEGIN
    RAISE NOTICE 'Quantity here is %', quantity;  -- Prints 30
    quantity := 50;
    --
    -- Create a subblock
    --
    DECLARE
        quantity integer := 80;
    BEGIN
        RAISE NOTICE 'Quantity here is %', quantity;  -- Prints 80
        RAISE NOTICE 'Outer quantity here is %', outerblock.quantity;  -- Prints 50
    END;

    RAISE NOTICE 'Quantity here is %', quantity;  -- Prints 50

    RETURN quantity;
END;
$$ LANGUAGE plpgsql;


--- Probar la función
SELECT somefunc()



--- Función que recibe un parámetro real y devuelve el 6 por ciente
CREATE OR REPLACE FUNCTION sales_tax(subtotal real) RETURNS real AS $$
BEGIN
    RETURN subtotal * 0.06;
END;
$$ LANGUAGE plpgsql;

--- Probar la función
SELECT sales_tax(18543.9)


--- Función que invoca a la función anterior y toma el resultado a una variable
CREATE OR REPLACE FUNCTION invoke_sales_tax(subtotal real) RETURNS real AS $$
DECLARE result real;
BEGIN
    result := (SELECT sales_tax(subtotal));
    RETURN (result);
END;
$$ LANGUAGE plpgsql;

--- Probar la función
SELECT invoke_sales_tax(18543.9)



--- Función que toma un entero y en forma condicional dice si es positivo
--- cero o negativo. el resultado no lo devuelve sino que lo muestra en consola
CREATE OR REPLACE FUNCTION condvalue (number integer) RETURNS void AS $$
DECLARE result char(40);
BEGIN
	IF number = 0 THEN
	    result := 'zero';
	ELSIF number > 0 THEN
	    result := 'positive';
	ELSIF number < 0 THEN
	    BEGIN
	       result := 'negative';
	    END;
	ELSE
	    -- hmm, the only other possibility is that number is null
	    result := 'NULL';
	END IF;
	RAISE NOTICE 'el resultado es: %', CAST(result AS char(10));
	--RETURN result;
END;
$$ LANGUAGE plpgsql


--- Probar la función
SELECT condvalue (-80)


--- Función para probar el uso de arreglos y un bucle
-- (lo probamos con for, foreach y con while)
CREATE OR REPLACE FUNCTION sum(arreglo int[]) RETURNS int8 AS $$
DECLARE
  s int8 := 0;
  x int;
BEGIN
  x:=1;
  --FOR x IN 1..array_length(arreglo,1)
  WHILE (x <= array_length(arreglo,1))
  LOOP
    s := s + arreglo[x];
	x:= x+1;
  END LOOP;
  RETURN s;
END;
$$ LANGUAGE plpgsql;

SELECT sum(ARRAY[6, 1, 3])


