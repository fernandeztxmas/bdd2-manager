CREATE OR REPLACE FUNCTION consulta_avion_col (colum char(30)) RETURNS integer AS $$
DECLARE
	 res int;
	 cmd char(100);
BEGIN
     cmd := 'SELECT ' || colum || ' FROM avion LIMIT 1';
	 RAISE NOTICE '%', cmd;
     EXECUTE cmd INTO res;
	 RAISE NOTICE '%',res;
	 RETURN res;
END;
$$ language plpgsql

